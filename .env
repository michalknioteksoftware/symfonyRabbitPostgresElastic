# In all cases, environment variables defined in .env.local will WIN over this file.
# DO NOT commit .env.local with production secrets to your repository.

APP_ENV=dev
APP_SECRET=changeme_generate_with_openssl_rand_hex_32

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:app@postgres:5432/app?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> symfony/messenger (RabbitMQ) ###
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
###< symfony/messenger ###

###> elasticsearch ###
ELASTICSEARCH_URL=http://elasticsearch:9200
###< elasticsearch ###

# Optional: override host ports exposed by Docker Compose
NGINX_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
ELASTICSEARCH_PORT=9200

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
