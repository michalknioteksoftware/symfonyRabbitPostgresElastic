<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Symfony 8 Boilerplate{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <header>
        <div class="logo">S</div>
        <div>
            <h1>{% block header_title %}Symfony 8 Boilerplate{% endblock %}</h1>
            <p>{% block header_sub %}PHP · PostgreSQL · Redis · RabbitMQ · Elasticsearch{% endblock %}</p>
        </div>
        {% block badges %}{% endblock %}
    </header>

    <nav>
        <a href="{{ path('welcome') }}"
           class="{{ app.request.attributes.get('_route') == 'welcome' ? 'active' : '' }}">
            Home
        </a>
        <a href="{{ path('article_web_index') }}"
           class="{{ app.request.attributes.get('_route') starts with 'article_web_' ? 'active' : '' }}">
            Articles
        </a>
        <a href="{{ path('health_check') }}">Health</a>
        <a href="{{ path('_profiler_home') }}">Profiler</a>
    </nav>

    <main>
        {% for type, messages in app.flashes(['success', 'error', 'warning']) %}
            {% for message in messages %}
                <div class="flash flash--{{ type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}{% endblock %}
</body>
</html>
